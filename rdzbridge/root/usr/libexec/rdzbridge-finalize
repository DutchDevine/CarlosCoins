#!/bin/sh
set -u

LOG='/etc/rdzbridge-firstboot.log'
READY='/etc/rdzbridge-ready.json'
rm -f "$READY"
exec >"$LOG" 2>&1

fail() {
	MESSAGE="$1"
	echo "ERROR: $MESSAGE"
	printf '{"status":"failed","error":"%s"}\n' "$(printf '%s' "$MESSAGE" | sed 's/["\\]/_/g')" > "$READY"
	chmod 0644 "$READY" 2>/dev/null || true
	sync
	exit 1
}

uci_set() {
	uci set "$1" || fail "UCI set failed: $1"
}

uci_commit() {
	uci commit "$1" || fail "UCI commit failed: $1"
}

ensure_section() {
	CONFIG="$1"
	SECTION="$2"
	TYPE="$3"
	uci -q get "$CONFIG.$SECTION" >/dev/null 2>&1 || uci_set "$CONFIG.$SECTION=$TYPE"
}

wait_for_service_enabled() {
	SERVICE="$1"
	MAX_WAIT="${2:-15}"
	ATTEMPT=0
	while [ "$ATTEMPT" -lt "$MAX_WAIT" ]; do
		if "/etc/init.d/$SERVICE" enabled >/dev/null 2>&1; then
			return 0
		fi
		if find /etc/rc.d -maxdepth 1 -type l -name "*${SERVICE}" -print -quit 2>/dev/null | grep -q .; then
			return 0
		fi
		ATTEMPT=$((ATTEMPT + 1))
		sleep 1
	done
	return 1
}

wait_for_http() {
	ATTEMPT=0
	while [ "$ATTEMPT" -lt 15 ]; do
		if wget -q -O /dev/null http://127.0.0.1/cgi-bin/luci/ >/dev/null 2>&1; then
			return 0
		fi
		ATTEMPT=$((ATTEMPT + 1))
		sleep 1
	done
	return 1
}

echo "RDZ first boot started: $(date -Iseconds 2>/dev/null || date)"

command -v uci >/dev/null 2>&1 || fail 'uci command is unavailable'
command -v find >/dev/null 2>&1 || fail 'find command is unavailable'
command -v wget >/dev/null 2>&1 || fail 'wget command is unavailable'

ensure_section network lan interface
ensure_section dhcp lan dhcp
ensure_section uhttpd main uhttpd
if ! uci -q get 'dropbear.@dropbear[0]' >/dev/null 2>&1; then
	uci add dropbear dropbear >/dev/null || fail 'Could not create Dropbear configuration section'
fi

echo 'Configuring LAN and DHCP'
uci_set 'network.lan.proto=static'
uci_set 'network.lan.ipaddr=10.77.77.1'
uci_set 'network.lan.netmask=255.255.255.0'
uci_set 'dhcp.lan.interface=lan'
uci_set 'dhcp.lan.ignore=0'
uci_set 'dhcp.lan.start=100'
uci_set 'dhcp.lan.limit=150'
uci_set 'dhcp.lan.leasetime=12h'

ETH=''
FALLBACK=''
DRIVER=''
ATTEMPT=0
while [ "$ATTEMPT" -lt 20 ] && [ -z "$ETH" ]; do
	FALLBACK=''
	for D in /sys/class/net/*; do
		N="${D##*/}"
		[ "$N" = lo ] && continue
		[ -d "$D/wireless" ] && continue
		[ -e "$D/device" ] || continue
		[ -z "$FALLBACK" ] && FALLBACK="$N"
		CURRENT_DRIVER="$(basename "$(readlink -f "$D/device/driver" 2>/dev/null)" 2>/dev/null)"
		if [ "$CURRENT_DRIVER" = r8169 ]; then
			ETH="$N"
			DRIVER="$CURRENT_DRIVER"
			break
		fi
	done

	if [ -z "$ETH" ] && [ -n "$FALLBACK" ]; then
		ETH="$FALLBACK"
		DRIVER="$(basename "$(readlink -f "/sys/class/net/$ETH/device/driver" 2>/dev/null)" 2>/dev/null)"
	fi

	[ -n "$ETH" ] && break
	ATTEMPT=$((ATTEMPT + 1))
	sleep 1
done

[ -n "$ETH" ] || fail 'No physical Ethernet interface found after 20 seconds'

echo "Using Ethernet interface: $ETH (driver: ${DRIVER:-unknown})"

uci -q delete network.br_lan >/dev/null 2>&1 || true
uci_set 'network.br_lan=device'
uci_set 'network.br_lan.name=br-lan'
uci_set 'network.br_lan.type=bridge'
uci add_list "network.br_lan.ports=$ETH" || fail "Could not add $ETH to br-lan"
uci_set 'network.lan.device=br-lan'

# LuCI must always be reachable over plain HTTP on the management LAN.
uci -q delete uhttpd.main.listen_http >/dev/null 2>&1 || true
uci add_list 'uhttpd.main.listen_http=0.0.0.0:80' || fail 'Could not configure HTTP listener'
uci add_list 'uhttpd.main.listen_http=[::]:80' || true
uci_set 'uhttpd.main.home=/www'
uci_set 'uhttpd.main.cgi_prefix=/cgi-bin'
uci_set 'uhttpd.main.redirect_https=0'
uci_set 'uhttpd.main.index_page=/cgi-bin/luci/admin/rdzbridge/overview'

uci_set 'dropbear.@dropbear[0].Interface=lan'
uci_set 'dropbear.@dropbear[0].PasswordAuth=on'

uci_commit network
uci_commit dhcp
uci_commit uhttpd
uci_commit dropbear

if command -v wifi >/dev/null 2>&1; then
	wifi config >/dev/null 2>&1 || true
fi

echo 'Enabling RDZ services and LuCI'
/etc/init.d/rdzbridge-watchdog enable || fail 'Could not enable RDZ watchdog'
/etc/init.d/rdzbridge-recovery enable || fail 'Could not enable RDZ recovery service'
/etc/init.d/uhttpd enable || fail 'Could not enable LuCI webserver'

wait_for_service_enabled rdzbridge-watchdog 15 || fail 'Watchdog enablement was not visible after 15 seconds'
wait_for_service_enabled rdzbridge-recovery 15 || fail 'Recovery service enablement was not visible after 15 seconds'
wait_for_service_enabled uhttpd 15 || fail 'LuCI webserver enablement was not visible after 15 seconds'

/etc/init.d/rdzbridge-watchdog start 2>/dev/null || true
/etc/init.d/network reload 2>/dev/null || true
/etc/init.d/dnsmasq restart 2>/dev/null || true
/etc/init.d/uhttpd restart 2>/dev/null || true
rm -f /tmp/luci-indexcache

for REQUIRED in \
	/www/luci-static/resources/view/rdzbridge/overview.js \
	/www/luci-static/resources/view/rdzbridge/setup.js \
	/usr/libexec/rdzbridge-connectivity-status \
	/usr/libexec/rdzbridge-reconnect \
	/usr/libexec/rdzbridge-finalize \
	/etc/init.d/rdzbridge-recovery \
	/etc/config/rdzbridge \
	/etc/config/network \
	/etc/config/dhcp \
	/etc/config/firewall \
	/etc/config/uhttpd; do
	[ -s "$REQUIRED" ] || fail "Required file missing or empty: $REQUIRED"
done

LAN_IP="$(uci -q get network.lan.ipaddr 2>/dev/null)"
[ "$LAN_IP" = '10.77.77.1' ] || fail "Unexpected LAN address: ${LAN_IP:-missing}"

LAN_DEVICE="$(uci -q get network.lan.device 2>/dev/null)"
[ "$LAN_DEVICE" = 'br-lan' ] || fail "Unexpected LAN device: ${LAN_DEVICE:-missing}"

BRIDGE_PORTS="$(uci -q get network.br_lan.ports 2>/dev/null)"
printf '%s\n' "$BRIDGE_PORTS" | grep -Fxq "$ETH" || fail "$ETH is not assigned to br-lan"

wait_for_http || fail 'LuCI did not become reachable on http://127.0.0.1 within 15 seconds'

cat > "$READY" <<EOF_READY
{"status":"ready","lan_ip":"10.77.77.1","lan_device":"br-lan","ethernet":"$ETH","driver":"${DRIVER:-unknown}","watchdog":"enabled","recovery":"enabled","luci":"http://10.77.77.1"}
EOF_READY
chmod 0644 "$READY"
echo "RDZ first boot completed: $(cat "$READY")"
sync
exit 0
